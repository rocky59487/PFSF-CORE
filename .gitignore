# ========================================
# Block Reality API + Fast Design + MctoNurbs
# Unified .gitignore
# ========================================

# --- Forge / Gradle build artifacts ---
**/build/
**/build-*/
**/run/
**/out/
**/.gradle/
**/mcmodsrepo/
**/src/generated/
**/bin/
**/logs/

# --- Compiled outputs ---
*.jar
*.class
*.dll
*.so
*.dylib

# --- Keep Gradle wrapper ---
!**/gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.properties

# --- IDE: IntelliJ IDEA ---
.idea/
*.iml
*.ipr
*.iws

# --- IDE: Eclipse ---
.classpath
.project
.settings/

# --- IDE: VS Code ---
.vscode/

# --- Forge MDK ---
forge-*-installer.jar

# --- Node.js (MctoNurbs sidecar) ---
**/node_modules/
**/dist/
*.js.map

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Environment / secrets ---
.env
*.env.local

# --- Log files ---
*.log

# --- Claude Code local settings ---
.claude/settings.local.json
.claude/plans/
.claude/memory/

# --- Git backup directories ---
*.git-backup/
.git-backup/

# --- Archived build artifacts in docs ---
docs/old/mpd.jar

# --- Exclude all zip files ---
*.zip

# --- Exclude .claude ---
.claude/

# --- Exclude git check files ---
.git_*.txt
commit_status*.txt
to_remove*.txt

# --- Exclude local session artifacts ---
L1-experiments/team-session/
L1-tooling/scripts/reorganize_ml.ps1

# --- Exclude all reports ---
*report*
*.docx

build/
.gradle/
out/
bin/
**/__pycache__/
*.pyc
*.pyo

# --- ML data / checkpoints / caches ---
*.npz
*.pkl
*.pth
*.ckpt
*.duckdb
mlflow.db
brnext_output/
hybr_output/
brnext_checkpoints/
reborn_ml_checkpoints/
hybr_minecraft_output/

# --- New ml/ directory artifacts ---
ml/experiments/outputs/
ml/experiments/checkpoints/
ml/experiments/cache/
ml/.venv/
ml/.venv_wsl/
*.onnx
*.msgpack

# --- Legacy venv backup ---
reborn-ml/.venv/
L1-legacy/reborn-ml/.venv/

# --- Logs ---
build_log.txt
fluid_train.err
fluid_train.log

# --- Debug / temporary dev artifacts (keep repo root clean) ---
# dumpbin / objdump output (happens occasionally when diagnosing
# native-library missing-import bugs — should never be committed):
imports.txt
**/imports.txt
**/*_imports.txt
# Developer scratch logs inside dev-scripts/ that should not be tracked:
dev-scripts/**/*.log
dev-scripts/**/out/

# --- ML experiments and GUI builds ---
ml/experiments/
ml/BR-Trainer-GUI/build/
ml/BR-Trainer-GUI/dist/
ml/data/
